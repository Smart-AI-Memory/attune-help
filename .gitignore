build/
dist/
*.egg-info/
*.egg
MANIFEST

# Unit test / coverage reports
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# Virtual environments
.venv/
venv/
env/
ENV/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# uv
.uv/

# Secrets
.env
.env.local
.pypirc

# Ignore .claude/ cruft (plans, worktrees, settings.local.json) but track
# the vendored session hooks + their wiring (see specs/sibling-claude-hooks/).
.claude/*
!.claude/hooks/
!.claude/settings.json

# Backup sidecars left by repolish_low_p1.py
*.pre-repolish.bak
